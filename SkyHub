local function corner(obj, radius)
    local c = Instance.new("UICorner", obj)
    c.CornerRadius = UDim.new(0, radius or 10)
    return c
end
local function stroke(obj, thickness, color)
    local s = Instance.new("UIStroke", obj)
    s.Thickness = thickness or 2
    s.Color = color or Color3.fromRGB(255,255,255)
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    return s
end
local function glowStroke(obj, color)
    local s = stroke(obj, 3, color or Color3.fromRGB(255,255,255))
    s.Transparency = 0.5
    return s
end
local function grad(obj, color1, color2, rotation)
    local g = Instance.new("UIGradient", obj)
    g.Color = ColorSequence.new(color1, color2)
    g.Rotation = rotation or 90
    return g
end
local function createGradient(obj, color1, color2, rotation)
    return grad(obj, color1, color2, rotation)
end

