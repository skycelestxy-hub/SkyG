local freecamActive=false; local freecamConn=nil; local freecamSpeedVal=40
local fcYaw=0; local fcPitch=0; local fcMouseConn=nil; local fcCharConn=nil
local fcSavedWalkSpeed=16; local fcSavedJumpPower=50

local function stopFreecam()
    freecamActive=false
    if freecamConn then freecamConn:Disconnect(); freecamConn=nil end
    if fcMouseConn then fcMouseConn:Disconnect(); fcMouseConn=nil end
    if fcCharConn  then fcCharConn:Disconnect();  fcCharConn=nil  end
    local cam=workspace.CurrentCamera; cam.CameraType=Enum.CameraType.Custom
    if player.Character then
        local hum3=player.Character:FindFirstChild("Humanoid")
        if hum3 then hum3.WalkSpeed=fcSavedWalkSpeed; hum3.JumpPower=fcSavedJumpPower; cam.CameraSubject=hum3 end
    end
    UserInputService.MouseBehavior=Enum.MouseBehavior.Default; UserInputService.MouseIconEnabled=true
    fcToggle.Text="OFF"; TW(fcToggle,0.2,{BackgroundColor3=Color3.fromRGB(70,75,95)}); fcSub.Text="Câmera livre sem o personagem"
end

local function startFreecam()
    freecamActive=true; freecamSpeedVal=40
    local cam=workspace.CurrentCamera; cam.CameraType=Enum.CameraType.Scriptable
    local cx,cy,_=cam.CFrame:ToEulerAnglesYXZ(); fcYaw=cy; fcPitch=cx
    local hum3=player.Character and player.Character:FindFirstChild("Humanoid")
    if hum3 then fcSavedWalkSpeed=hum3.WalkSpeed; fcSavedJumpPower=hum3.JumpPower; hum3.WalkSpeed=0; hum3.JumpPower=0 end
    UserInputService.MouseBehavior=Enum.MouseBehavior.LockCenter; UserInputService.MouseIconEnabled=false
    fcToggle.Text="ON"; TW(fcToggle,0.2,{BackgroundColor3=Color3.fromRGB(0,200,120)}); fcSub.Text="WASD+QE mover • Mouse girar • Scroll=vel • F=sair"
    fcMouseConn=UserInputService.InputChanged:Connect(function(inp)
        if not freecamActive then return end
        if inp.UserInputType==Enum.UserInputType.MouseMovement then
            fcYaw=fcYaw-inp.Delta.X*0.003; fcPitch=math.clamp(fcPitch-inp.Delta.Y*0.003,-math.pi/2+0.05,math.pi/2-0.05)
        elseif inp.UserInputType==Enum.UserInputType.MouseWheel then
            freecamSpeedVal=math.clamp(freecamSpeedVal+inp.Position.Z*8,3,300); fcSub.Text=string.format("Vel: %.0f  |  WASD+QE mover",freecamSpeedVal)
        end
    end)
    freecamConn=RunService.RenderStepped:Connect(function(dt)
        if not freecamActive then return end
        local rot=CFrame.Angles(0,fcYaw,0)*CFrame.Angles(fcPitch,0,0)
        local newCF=CFrame.new(cam.CFrame.Position)*rot; local move=Vector3.zero
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then move=move+newCF.LookVector  end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then move=move-newCF.LookVector  end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then move=move-newCF.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then move=move+newCF.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.E) or UserInputService:IsKeyDown(Enum.KeyCode.Space)     then move=move+Vector3.new(0,1,0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.Q) or UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then move=move-Vector3.new(0,1,0) end
        cam.CFrame=move.Magnitude>0 and CFrame.new(cam.CFrame.Position+move.Unit*freecamSpeedVal*dt)*rot or newCF
    end)
    fcCharConn=UserInputService.InputBegan:Connect(function(inp,proc)
        if proc then return end; if inp.KeyCode==Enum.KeyCode.F then stopFreecam() end
    end)
end
