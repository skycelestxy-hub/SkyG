local espRenderConn = nil
local function startESPRender()
    if espRenderConn then return end
    local cam = workspace.CurrentCamera
    espRenderConn = RunService.RenderStepped:Connect(function()
        if not Features.esp.enabled then return end
        local viewSize   = cam.ViewportSize
        local tracerFrom = Vector2.new(viewSize.X/2, viewSize.Y)
        local localRoot  = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        for _, p in pairs(Players:GetPlayers()) do
            if p == player then continue end
            local data = espData[p]
            if not data then data = createESPDrawings(p); espData[p] = data end
            local char  = p.Character
            local pRoot = char and char:FindFirstChild("HumanoidRootPart")
            local pHead = char and char:FindFirstChild("Head")
            if not pRoot or not pHead then
                data.tracer.Visible=false; data.nameLabel.Visible=false; data.distLabel.Visible=false
                if char then addHighlight(p) end; continue
            end
            local headScreen,headOnScreen = cam:WorldToViewportPoint(pHead.Position+Vector3.new(0,0.5,0))
            local rootScreen,_            = cam:WorldToViewportPoint(pRoot.Position)
            if not headOnScreen or headScreen.Z<=0 then
                data.tracer.Visible=false; data.nameLabel.Visible=false; data.distLabel.Visible=false; continue
            end
            local dist      = localRoot and math.round((localRoot.Position-pRoot.Position).Magnitude) or 0
            local distColor = getDistanceColor(dist)
            local screenHead= Vector2.new(headScreen.X,headScreen.Y)
            local screenFeet= Vector2.new(rootScreen.X,rootScreen.Y)
            data.tracer.Visible=true; data.tracer.From=tracerFrom; data.tracer.To=screenFeet
            data.tracer.Color=distColor; data.tracer.Transparency=math.clamp(1-(dist/300),0.3,1)
            data.nameLabel.Visible=true; data.nameLabel.Text=p.Name
            data.nameLabel.Position=Vector2.new(screenHead.X,screenHead.Y-18); data.nameLabel.Color=distColor
            data.distLabel.Visible=true; data.distLabel.Text=dist.." studs"
            data.distLabel.Position=Vector2.new(screenHead.X,screenHead.Y-4)
            data.distLabel.Color=Color3.fromRGB(180,180,180)
            addHighlight(p)
        end
    end)
