local KEY_VALIDATION_URL = "https://skyhub-keys.skycelestxy.workers.dev/"

local function validarKey(key)
    if #key ~= 14 then return false, "Formato inválido (14 chars)" end
    if not key:match("^SKYHub[A-Z0-9][A-Z0-9][A-Z0-9][A-Z0-9][A-Z0-9][A-Z0-9][A-Z0-9]V$") then
        return false, "Formato incorreto"
    end
    local response, body
    -- request() — Synapse X, KRNL, Fluxus, etc.
    local ok = pcall(function()
        response = request({Url=KEY_VALIDATION_URL, Method="GET"})
        body = response.Body
    end)
    -- http.request() — verifica se http E http.request existem antes de chamar
    if not ok or not body then
        ok = pcall(function()
            local fn = type(http)=="table" and rawget(http,"request") or nil
            if type(fn)=="function" then
                response = fn({Url=KEY_VALIDATION_URL, Method="GET"})
                body = response.Body
            end
        end)
    end
    -- syn.request() — verifica se syn E syn.request existem antes de chamar
    if not ok or not body then
        ok = pcall(function()
            local fn = type(syn)=="table" and rawget(syn,"request") or nil
            if type(fn)=="function" then
                response = fn({Url=KEY_VALIDATION_URL, Method="GET"})
                body = response.Body
            end
        end)
    end
    if not ok or not body or body=="" then return false, "Sem conexão com servidor" end
    local decoded
    local ok2 = pcall(function() decoded = HttpService:JSONDecode(body) end)
    if not ok2 or not decoded then return false, "Erro ao ler dados" end
    local keyData = decoded.keys and decoded.keys[key]
    if not keyData then return false, "Key não encontrada" end
    if keyData.status == "expirada" then return false, "Key expirada"  end
    if keyData.status == "deletada" then return false, "Key removida"  end
    if keyData.status ~= "ativa"    then return false, "Key inválida"  end
    if keyData.online == true       then return false, "Key já em uso em outro dispositivo" end
    return true, "OK"
end

