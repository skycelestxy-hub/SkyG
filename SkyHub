local function animateActivation(elements,enabled)
    local tC=enabled and Design.colors.cardOn or Design.colors.cardOff
    local bC=enabled and Design.colors.buttonOn or Design.colors.buttonOff
    local bG=enabled and Color3.fromRGB(0,200,120) or Color3.fromRGB(60,65,85)
    local iC=enabled and Color3.fromRGB(255,255,255) or getTheme().text
    if elements.buttonText then elements.buttonText.Text=enabled and "ON" or "OFF" end
    TW(elements.frame,Design.animation.normal,{BackgroundColor3=tC})
    TW(elements.glow,Design.animation.slow,{ImageTransparency=enabled and 0.6 or 1})
    TW(elements.button,Design.animation.normal,{BackgroundColor3=bC})
    elements.buttonGradient.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,bC),ColorSequenceKeypoint.new(1,bG)})
    TW(elements.icon,Design.animation.normal,{TextColor3=iC})
    TW(elements.title,Design.animation.normal,{TextColor3=enabled and Color3.fromRGB(255,255,255) or getTheme().text})
    TW(elements.border,Design.animation.normal,{Transparency=enabled and 0.3 or 0.85})
end

